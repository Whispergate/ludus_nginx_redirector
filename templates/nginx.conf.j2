user {{ nginx_user }};
worker_processes {{ nginx_worker_processes }};
error_log /var/log/nginx/error.log warn;
pid /var/run/nginx.pid;

{% if nginx_hide_version %}
# Hide nginx version
server_tokens off;
{% endif %}

events {
    worker_connections {{ nginx_worker_connections }};
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    log_format main {{ nginx_log_format_main }};

    access_log /var/log/nginx/access.log main;

    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout {{ nginx_keepalive_timeout }};
    types_hash_max_size 2048;
    client_max_body_size {{ client_max_body_size }};
    client_body_timeout {{ client_body_timeout }};
    client_header_timeout {{ client_header_timeout }};

    # Proxy timeouts
    proxy_connect_timeout {{ nginx_connect_timeout }}s;
    proxy_send_timeout {{ nginx_send_timeout }}s;
    proxy_read_timeout {{ nginx_read_timeout }}s;
    proxy_buffering {{ nginx_proxy_buffering }};

    # DNS Resolution for upstreams
    resolver {{ resolver }};
    resolver_timeout {{ resolver_timeout }};

{% if enable_gzip %}
    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_level {{ gzip_level }};
    gzip_types {{ gzip_types }};
{% endif %}

{% for option in nginx_http_additional_options %}
    {{ option }}
{% endfor %}

{% if enable_rate_limiting %}
    # Rate limiting
    limit_req_zone $binary_remote_addr zone={{ rate_limit_zone }}:10m rate={{ rate_limit_requests }};
{% endif %}

    # Include additional configurations
    include /etc/nginx/conf.d/*.conf;
}
